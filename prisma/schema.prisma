// ======================
//  Roster Rules Enforcement (2026-04-21 plan)
// ======================

/**
 * Append-only log of every IL slot transition. The IL fee reconciler
 * computes billable stints directly from this table instead of pairing
 * TransactionEvent rows — removes a fragile indirection for money-sensitive
 * accounting (see plan architecture review).
 * Each (IL_STASH, IL_ACTIVATE, IL_RELEASE) row is written inside the same
 * transaction as the Roster mutation that caused it. Commissioner backdates
 * use the effective date as effDate, not now().
 */
model RosterSlotEvent {
  id                 Int       @id @default(autoincrement())
  teamId             Int
  playerId           Int
  leagueId           Int
  event              String // "IL_STASH" | "IL_ACTIVATE" | "IL_RELEASE"
  effDate            DateTime // respects commissioner backdate; anchored at UTC midnight
  createdAt          DateTime  @default(now())
  createdBy          Int? // user id of actor
  reason             String? // optional commissioner justification
  // Evidence capture — what the MLB feed returned at stash time. Best-effort
  // freshness marker; not load-bearing for enforcement, used for audit.
  mlbStatusSnapshot  String?
  mlbStatusFetchedAt DateTime?

  team   Team   @relation(fields: [teamId], references: [id])
  player Player @relation(fields: [playerId], references: [id])
  league League @relation(fields: [leagueId], references: [id])

  // Idempotency — prevents duplicate IL_STASH events for same (team, player,
  // effDate) from re-playing a commissioner action.
  @@unique([teamId, playerId, effDate, event])
  @@index([leagueId, effDate])
  @@index([teamId, playerId, effDate])
}

/**
 * Durable queue for post-commit side effects. When a transaction needs to
 * trigger async work (e.g., IL fee reconciliation spanning a closed period),
 * it inserts a row here inside the originating transaction. A separate
 * drainer picks up uncompleted rows and processes them under its own
 * advisory lock.
 * Initial implementation: in-process setInterval-based drainer. Forward-
 * compatible with pg-boss if/when FBST goes multi-container.
 */
model OutboxEvent {
  id          Int       @id @default(autoincrement())
  kind        String // "IL_FEE_RECONCILE" etc.
  payload     Json
  attempts    Int       @default(0)
  lastError   String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([completedAt, createdAt])
  @@index([kind, completedAt])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 3: Scoring Engine Models (NFL/NBA H2H)
// ═══════════════════════════════════════════════════════════════════════════════

model ScoringSettings {
  id            Int          @id @default(autoincrement())
  leagueId      Int          @unique
  sport         Sport
  scoringType   ScoringType
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  league League         @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  rules  ScoringRule[]

  @@index([leagueId, sport])
}

model ScoringRule {
  id                Int             @id @default(autoincrement())
  scoringSettingsId Int
  statKey           String
  label             String
  pointValue        Float
  isActive          Boolean         @default(true)
  sortOrder         Int             @default(0)
  isCustom          Boolean         @default(false)

  scoringSettings ScoringSettings @relation(fields: [scoringSettingsId], references: [id], onDelete: Cascade)

  @@unique([scoringSettingsId, statKey])
  @@index([scoringSettingsId])
  @@index([isActive])
}

model RosterConfig {
  id        Int      @id @default(autoincrement())
  leagueId  Int      @unique
  sport     Sport
  slots     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId, sport])
}

model H2HMatchup {
  id          Int                 @id @default(autoincrement())
  leagueId    Int
  sport       Sport
  week        Int
  season      String
  homeTeamId  Int
  awayTeamId  Int
  homeScore   Float?
  awayScore   Float?
  status      H2HMatchupStatus    @default(SCHEDULED)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  league       League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  homeTeam     Team         @relation("H2HMatchupHome", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam     Team         @relation("H2HMatchupAway", fields: [awayTeamId], references: [id], onDelete: Cascade)
  statLines    StatLine[]

  @@unique([leagueId, sport, week, season, homeTeamId, awayTeamId])
  @@index([leagueId, sport, week, season])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([status])
}

model StatLine {
  id             Int      @id @default(autoincrement())
  h2hMatchupId   Int
  playerId       Int
  teamId         Int
  week           Int
  season         String
  sport          Sport
  stats          Json
  fantasyPoints  Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  h2hMatchup H2HMatchup @relation(fields: [h2hMatchupId], references: [id], onDelete: Cascade)
  player     Player     @relation("StatLinePlayer", fields: [playerId], references: [id], onDelete: Cascade)
  team       Team       @relation("StatLineTeam", fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([h2hMatchupId, playerId])
  @@index([h2hMatchupId])
  @@index([playerId])
  @@index([teamId])
  @@index([week, season, sport])
}
