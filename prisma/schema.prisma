// prisma/schema.prisma

// ======================
//  Datasource + Generator
// ======================
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../server/node_modules/.prisma/client"
}

// ======================
//  Enums
// ======================

enum DraftMode {
  AUCTION
  DRAFT
}

enum DraftOrder {
  SNAKE
  LINEAR
}

// NEW: League roles for access control
enum LeagueRole {
  COMMISSIONER
  OWNER
}

enum TradeStatus {
  PROPOSED
  ACCEPTED
  REJECTED
  VETOED
  PROCESSED
  CANCELLED
  REVERSED
}

enum AssetType {
  PLAYER
  BUDGET
  PICK
  FUTURE_BUDGET
  WAIVER_PRIORITY
}

enum ClaimStatus {
  PENDING
  SUCCESS
  FAILED_OUTBID
  FAILED_INVALID
  FAILED_CONDITION
  CANCELLED
}

// ──────────────────────────────────────────────────────────────────
// Waiver Wire List enums (PR #256, two-list model)
// ──────────────────────────────────────────────────────────────────

enum WaiverDropMode {
  RELEASE
  IL_STASH
}

enum WaiverPeriodStatus {
  PENDING
  LOCKED
  PROCESSED
  CANCELLED
}

enum WaiverAddOutcome {
  PENDING
  SUCCEEDED
  FAILED
  SKIPPED
}

enum WaiverDropStatus {
  PENDING
  CONSUMED
  UNUSED
}

enum SeasonStatus {
  SETUP
  DRAFT
  IN_SEASON
  COMPLETED
}

enum Sport {
  MLB
  NFL
  NBA
}

enum ScoringType {
  POINTS
  CATEGORIES
}

enum H2HMatchupStatus {
  SCHEDULED
  LIVE
  FINAL
}

// ======================
//  Models
// ======================

model Franchise {
  id                Int      @id @default(autoincrement())
  name              String   @unique
  sport             Sport?
  abbreviation      String?
  externalId        String?
  logoUrl           String?
  isPublic          Boolean  @default(false)
  publicSlug        String?  @unique
  inviteCode        String?  @unique
  tradeReviewPolicy String   @default("COMMISSIONER")
  vetoThreshold     Int      @default(4)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  leagues           League[]
  memberships       FranchiseMembership[]
  players           Player[]
  schedulesHome     Schedule[] @relation("HomeFranchise")
  schedulesAway     Schedule[] @relation("AwayFranchise")
}

model FranchiseMembership {
  id          Int        @id @default(autoincrement())
  franchiseId Int
  userId      Int
  role        LeagueRole
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  franchise Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([franchiseId, userId])
  @@index([userId])
  @@index([franchiseId])
}

model User {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  name         String?
  avatarUrl    String?
  googleSub    String? @unique
  yahooSub     String? @unique
  passwordHash String?

  resetToken        String?   @unique
  resetTokenExpires DateTime?

  venmoHandle  String?
  zelleHandle  String?
  paypalHandle String?

  isAdmin Boolean @default(false)

  memberships          LeagueMembership[]
  franchiseMemberships FranchiseMembership[]
  ownedTeams           Team[]                @relation("TeamOwner")
  teamOwnerships       TeamOwnership[]
  auditLogs            AuditLog[]
  boardCards           BoardCard[]
  boardReplies         BoardCardReply[]
  productBoardCards    ProductBoardCard[]    @relation("ProductBoardCards")
  productBoardReplies  ProductBoardReply[]   @relation("ProductBoardReplies")

  pushSubscriptions      PushSubscription[]
  notificationPreference NotificationPreference?
  chatMessages           ChatMessage[]
  profile                UserProfile?

  userSessions UserSession[]
  userMetrics  UserMetrics?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ======================
//  Session tracking (Session 63 — per docs/plans/2026-04-13-admin-users-session-tracking-plan.md)
// ======================

/// One row per browser per login cycle. Multi-tab coordination via
/// BroadcastChannel keeps this at one row per browser, not per tab.
/// lastSeenAt is deliberately NOT indexed — preserves Postgres HOT updates
/// and avoids dead-tuple bloat (see plan R6).
model UserSession {
  id     Int    @id @default(autoincrement())
  token  String @unique @default(cuid())
  userId Int

  ipHash      String? // HMAC-SHA256(raw ip, env.IP_HASH_SECRET)
  ipTruncated String? // /24 for IPv4, /48 for IPv6 — retained 90d
  ipRaw       String? // full IP, purged at 7d (fraud window only)
  userAgent   String? @db.Text
  country     String? // Cloudflare CF-IPCountry

  startedAt   DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  endedAt     DateTime?
  durationSec Int?
  endReason   String? // "logout" | "idle" | "sweeper" | "session_cap"

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}

/// Denormalized rollup — one row per user. Heartbeats do NOT write here
/// (plan R5). Duration is rolled up on session-end / sweeper.
model UserMetrics {
  userId                   Int       @id
  totalLogins              Int       @default(0)
  totalSessions            Int       @default(0)
  totalSecondsOnSite       Int       @default(0)
  avgSessionSec            Int       @default(0)
  leaguesOwnedCount        Int       @default(0)
  leaguesCommissionedCount Int       @default(0)
  firstSeenAt              DateTime
  lastSeenAt               DateTime
  lastLoginAt              DateTime?
  lastActivityAt           DateTime?
  signupSource             String? // "google" | "yahoo" | "email" | "invite"
  signupUtmSource          String?
  signupUtmCampaign        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastSeenAt(sort: Desc)])
  @@index([lastLoginAt(sort: Desc)])
}

/// Non-cascading log written BEFORE user deletion cascade runs.
/// Preserves audit trail after GDPR right-to-erasure wipes everything else.
model UserDeletionLog {
  id        Int      @id @default(autoincrement())
  userId    Int // original id, not FK — survives cascade
  emailHash String // HMAC(email, IP_HASH_SECRET)
  deletedAt DateTime @default(now())
  deletedBy Int? // admin id if admin-initiated, null if self-delete
  reason    String?
  metadata  Json?

  @@index([deletedAt])
}

model UserProfile {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique
  bio              String?  @db.VarChar(200)
  favoriteTeam     String? // MLB team abbreviation (e.g. "LAD", "NYY")
  experienceLevel  String? // "1-3", "3-5", "5-10", "10+"
  preferredFormats String[] @default([]) // ["ROTO", "H2H", "KEEPER", "DYNASTY", "POINTS"]
  paymentHandles   Json? // { venmo?: string, paypal?: string, zelle?: string, cashapp?: string }
  timezone         String? // IANA timezone (e.g. "America/Los_Angeles")
  isPublic         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model League {
  id         Int         @id @default(autoincrement())
  name       String
  season     Int
  draftMode  DraftMode
  draftOrder DraftOrder?
  createdAt  DateTime    @default(now())

  // Sport type — MLB, NFL, NBA
  sport Sport @default(MLB)

  isPublic   Boolean @default(false)
  publicSlug String? @unique
  inviteCode String? @unique

  // Scoring Format (ROTO default protects existing leagues like OGBA)
  scoringFormat      String @default("ROTO") // "ROTO" | "H2H_CATEGORIES" | "H2H_POINTS"
  pointsConfig       Json? // Points scoring weights: { "R": 1, "HR": 4, "RBI": 1, "SB": 2, ... }
  playoffWeeks       Int    @default(3)
  playoffTeams       Int    @default(4)
  regularSeasonWeeks Int    @default(20)

  // Trade Settings
  tradeReviewPolicy String @default("COMMISSIONER") // COMMISSIONER, LEAGUE_VOTE
  vetoThreshold     Int    @default(4)

  // Waiver Configuration
  waiverType        String    @default("FAAB") // FAAB, ROLLING_PRIORITY, REVERSE_STANDINGS, FREE_AGENT
  faabBudget        Int       @default(200)
  faabMinBid        Int       @default(0)
  waiverPeriodDays  Int       @default(2)
  processingFreq    String    @default("DAILY") // DAILY, WEEKLY_WED, WEEKLY_SUN, etc.
  faabTiebreaker    String    @default("ROLLING_PRIORITY") // ROLLING_PRIORITY, REVERSE_STANDINGS, RANDOM
  acquisitionLimit  Int? // null = unlimited
  conditionalClaims Boolean   @default(true)
  tradeDeadline     DateTime?
  rosterLockTime    String? // "GAME_TIME" or "DAILY_LOCK"

  // League Discovery & Capacity
  visibility   String  @default("PRIVATE") // PRIVATE, PUBLIC, OPEN
  maxTeams     Int     @default(12)
  description  String? @db.Text
  entryFee     Float?
  entryFeeNote String?

  // Franchise FK (org-level parent)
  franchiseId Int
  franchise   Franchise @relation(fields: [franchiseId], references: [id])

  teams                  Team[]
  memberships            LeagueMembership[]
  transactions           TransactionEvent[]
  historicalSeasons      HistoricalSeason[]
  rules                  LeagueRule[]
  trades                 Trade[]
  seasons                Season[]
  periods                Period[]
  auctionSession         AuctionSession?
  snakeDraftSession      SnakeDraftSession?
  draftPicks             DraftPick[]
  matchups               Matchup[]
  invites                LeagueInvite[]
  playerValues           PlayerValue[]
  aiInsights             AiInsight[]
  boardCards             BoardCard[]
  chatMessages           ChatMessage[]
  rosterSlotEvents       RosterSlotEvent[]
  teamStatsCategoryDaily TeamStatsCategoryDaily[]
  waiverPeriods          WaiverPeriod[]
  scoringSettings        ScoringSettings?
  rosterConfig           RosterConfig?
  h2hMatchups            H2HMatchup[]

  @@unique([name, season])
}

// Dynamic Rules Management
model LeagueRule {
  id       Int    @id @default(autoincrement())
  leagueId Int
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  category String // "overview", "roster", "scoring", "draft", "trades", "bonuses", "payouts"
  key      String // "team_count", "budget", "keeper_count", etc.
  value    String // JSON string for complex values
  label    String // Display label for UI

  isLocked Boolean @default(false) // Locked after season start

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leagueId, category, key])
  @@index([leagueId])
}

model LeagueMembership {
  id       Int        @id @default(autoincrement())
  leagueId Int
  userId   Int
  role     LeagueRole

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leagueId, userId])
  @@index([userId])
  @@index([leagueId])
  @@index([leagueId, role])
}

// Multi-owner support (up to 2 owners per team)
model TeamOwnership {
  id     Int @id @default(autoincrement())
  teamId Int
  userId Int

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model Team {
  id        Int      @id @default(autoincrement())
  leagueId  Int
  name      String
  owner     String?
  budget    Int      @default(400)
  createdAt DateTime @default(now())

  code        String?
  ownerUserId Int?
  ownerUser   User?   @relation("TeamOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  // Multi-owner support
  ownerships TeamOwnership[]

  // Link to prior year team for historical tracking
  priorTeamId Int?
  priorTeam   Team?  @relation("TeamHistory", fields: [priorTeamId], references: [id], onDelete: SetNull)
  nextTeams   Team[] @relation("TeamHistory")

  league           League                   @relation(fields: [leagueId], references: [id])
  rosters          Roster[]
  stats            TeamStatsPeriod[]
  season           TeamStatsSeason?
  financeEvents    FinanceLedger[]
  rosterSlotEvents RosterSlotEvent[]
  categoryDaily    TeamStatsCategoryDaily[]

  // ADD THIS:
  transactions TransactionEvent[]
  auctionBids  AuctionBid[]

  // Optimistic-concurrency guard for roster hub (todo #181).
  // Incremented on every roster mutation so the hub client can detect stale writes.
  rosterVersion Int @default(0)

  // Waiver priority override (commissioner-set; overrides computed standings-based rank)
  waiverPriorityOverride Int?

  // Trade Block: JSON array of playerIds the owner has flagged as available for trade
  tradeBlockPlayerIds Json @default("[]")

  // Trade Relations
  proposedTrades     Trade[]     @relation("TradeProposer")
  tradeItemsSent     TradeItem[] @relation("TradeSender")
  tradeItemsReceived TradeItem[] @relation("TradeRecipient")

  // Waiver Relations
  waiverClaims WaiverClaim[]

  // AI Insights
  aiInsights AiInsight[]

  // Watchlist + Trading Block
  watchlist    Watchlist[]
  tradingBlock TradingBlock[]

  // Snake Draft + H2H Matchups
  draftPicks  DraftPick[]
  matchupsAsA Matchup[]   @relation("matchupTeamA")
  matchupsAsB Matchup[]   @relation("matchupTeamB")

  // Waiver Wire List (PR #256, two-list model)
  waiverAddEntries  WaiverAddEntry[]
  waiverDropEntries WaiverDropEntry[]

  // Phase 3: H2H Matchups (NFL/NBA)
  h2hMatchupsHome H2HMatchup[] @relation("H2HMatchupHome")
  h2hMatchupsAway H2HMatchup[] @relation("H2HMatchupAway")
  statLines       StatLine[]   @relation("StatLineTeam")

  @@unique([leagueId, name])
  @@unique([leagueId, code])
  @@index([leagueId])
  @@index([ownerUserId])
}

model Player {
  id Int @id @default(autoincrement())

  // Canonical internal integration key (do not expose to UI).
  // Keep nullable for now to avoid breaking existing rows; Postgres UNIQUE allows many NULLs.
  mlbId Int? @unique

  sport             Sport?
  name              String
  posPrimary        String
  posList           String // comma-separated for now
  franchiseId       Int?
  externalId        String?
  mlbTeam           String? // e.g. "LAD", "NYY"

  /// Raw MLB statsapi roster status string ("Active", "Injured 10-Day",
  /// "Injured 60-Day", "Restricted", …). Verbatim per direction-lock IL #1
  /// — never normalized. Powers the v3 hub ghost-IL warning chip and the
  /// `isMlbIlStatusUi` eligibility gate. Populated by the daily
  /// `syncAllPlayers` cron from each team's 40-man roster `status.description`.
  mlbStatus String?

  /// Per-position games-played map populated by the daily syncPositionEligibility
  /// cron from the MLB Stats API fielding group. Keys are position abbreviations
  /// ("OF", "2B", "SS", …). Null until the cron first runs for a player.
  posGames  Json?

  createdAt DateTime @default(now())

  franchise         Franchise? @relation(fields: [franchiseId], references: [id], onDelete: SetNull)
  rosters           Roster[]
  lots                  AuctionLot[]
  aliases               PlayerAlias[]
  transactions          TransactionEvent[]
  tradeItems            TradeItem[]
  waiverClaimsAdd       WaiverClaim[]       @relation("ClaimAdd")
  waiverClaimsDrop      WaiverClaim[]       @relation("ClaimDrop")
  waiverClaimsCondition WaiverClaim[]       @relation("ClaimCondition")
  waiverAddEntries      WaiverAddEntry[]    @relation("WaiverAddPlayer")
  waiverDropEntries     WaiverDropEntry[]   @relation("WaiverDropPlayer")
  periodStats           PlayerStatsPeriod[]
  dailyStats            PlayerStatsDaily[]
  playerValues          PlayerValue[]
  draftPicks            DraftPick[]
  watchlistEntries      Watchlist[]
  tradingBlockEntries   TradingBlock[]
  rosterSlotEvents      RosterSlotEvent[]
  financeLedgerEntries  FinanceLedger[]
  statLines             StatLine[]      @relation("StatLinePlayer")

  @@index([name])
}

model PlayerAlias {
  id       Int @id @default(autoincrement())
  playerId Int

  // e.g. "onroto"
  source String

  // e.g. "NArenado", "HyeKim"
  alias String

  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([source, alias])
  @@index([playerId])
  @@index([alias])
}

model TransactionEvent {
  id Int @id @default(autoincrement())

  // Your parser’s idempotency key (md5 over raw fields)
  rowHash String @unique

  leagueId Int
  season   Int

  // Best-effort parsed timestamps
  effDate     DateTime?
  submittedAt DateTime?

  // Raw strings from HTML (keep them for traceability/debugging)
  effDateRaw     String?
  submittedRaw   String?
  ogbaTeamName   String?
  playerAliasRaw String?
  mlbTeamAbbr    String?
  transactionRaw String?

  // Normalized “types” (optional, but useful)
  transactionType String?
  toPosition      String?

  // Joins (optional until mapped)
  teamId   Int?
  playerId Int?

  createdAt DateTime @default(now())

  league League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)
  player Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([leagueId, season])
  @@index([teamId])
  @@index([playerId])
  @@index([submittedAt])
  @@index([leagueId, submittedAt])
  // Roster-rules-plan indexes (2026-04-21): stint derivation + backdate
  // affected-period lookups.
  @@index([leagueId, transactionType, effDate])
  @@index([teamId, playerId, effDate])
  // standings query: playerId IN (...) + transactionType IN ('IL_STASH','IL_ACTIVATE') + effDate IS NOT NULL
  @@index([playerId, transactionType, effDate])
}

model Season {
  id        Int          @id @default(autoincrement())
  leagueId  Int
  year      Int
  status    SeasonStatus @default(SETUP)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  league  League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  periods Period[]

  @@unique([leagueId, year])
  @@index([leagueId])
  @@index([leagueId, status])
}

model Period {
  id        Int      @id @default(autoincrement())
  name      String
  startDate DateTime
  endDate   DateTime
  status    String

  leagueId Int?
  seasonId Int?

  league League? @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season Season? @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  teamStats     TeamStatsPeriod[]
  playerStats   PlayerStatsPeriod[]
  matchups      Matchup[]
  financeLedger FinanceLedger[]

  @@unique([seasonId, name])
  @@index([leagueId])
  @@index([seasonId])
  @@index([leagueId, status])
  @@index([leagueId, startDate, endDate])
}

model TeamStatsPeriod {
  id       Int @id @default(autoincrement())
  teamId   Int
  periodId Int

  // Batting
  R   Int   @default(0)
  HR  Int   @default(0)
  RBI Int   @default(0)
  SB  Int   @default(0)
  AVG Float @default(0)

  // Pitching
  W    Int   @default(0)
  S    Int   @default(0) // saves
  ERA  Float @default(0)
  WHIP Float @default(0)
  K    Int   @default(0)

  // Misc
  gamesPlayed Int @default(0)

  team   Team   @relation(fields: [teamId], references: [id])
  period Period @relation(fields: [periodId], references: [id])

  @@unique([teamId, periodId])
}

/// Daily snapshot of team category totals + rank-points. Populated by the
/// 11:00 UTC daily cron in server/src/index.ts (after the 13:00 UTC stats
/// sync — confirm ordering when shipping). Powers day-over-day deltas on
/// CategoryStandingsView and any future "stat-of-the-week" / "biggest
/// mover" features.
///
/// Storage estimate: 8 teams × 10 categories × 365 days × N leagues =
/// 29,200 rows/league/year. Trivial for Postgres.
model TeamStatsCategoryDaily {
  id         Int      @id @default(autoincrement())
  teamId     Int
  leagueId   Int
  date       DateTime @db.Date
  category   String // CategoryKey: "R" | "HR" | "RBI" | "SB" | "AVG" | "W" | "S" | "K" | "ERA" | "WHIP"
  value      Float // raw category value at end of day
  rank       Int // 1 = best in this category for that day
  rankPoints Int // 8 for 1st in 8-team league, 7 for 2nd, etc.

  team   Team   @relation(fields: [teamId], references: [id])
  league League @relation(fields: [leagueId], references: [id])

  @@unique([teamId, leagueId, date, category])
  @@index([leagueId, date])
  @@index([teamId, category, date])
}

/// @deprecated Use TeamStatsPeriod aggregation instead. Table left in DB for backward compat; no code reads this.
model TeamStatsSeason {
  id     Int @id @default(autoincrement())
  teamId Int @unique

  // Batting
  R   Int   @default(0)
  HR  Int   @default(0)
  RBI Int   @default(0)
  SB  Int   @default(0)
  AVG Float @default(0)

  // Pitching
  W    Int   @default(0)
  S    Int   @default(0)
  ERA  Float @default(0)
  WHIP Float @default(0)
  K    Int   @default(0)

  gamesPlayed Int @default(0)

  team Team @relation(fields: [teamId], references: [id])
}

model PlayerStatsPeriod {
  id       Int @id @default(autoincrement())
  playerId Int
  periodId Int

  // Batting
  AB  Int @default(0)
  H   Int @default(0)
  R   Int @default(0)
  HR  Int @default(0)
  RBI Int @default(0)
  SB  Int @default(0)

  // Batting — extended (from MLB API, for MVP/award tracking)
  BB    Int   @default(0) // walks (baseOnBalls)
  HBP   Int   @default(0) // hit by pitch
  SF    Int   @default(0) // sacrifice flies
  TB    Int   @default(0) // total bases
  DBL   Int   @default(0) // doubles
  TPL   Int   @default(0) // triples
  SO    Int   @default(0) // strikeouts (batting)
  OBP   Float @default(0)
  SLG   Float @default(0)
  OPS   Float @default(0)
  GS_HR Int   @default(0) // grand slams

  // Pitching
  W    Int   @default(0)
  SV   Int   @default(0)
  K    Int   @default(0)
  IP   Float @default(0)
  ER   Int   @default(0)
  BB_H Int   @default(0) // walks + hits allowed (for WHIP)

  // Pitching — extended (from MLB API, for Cy Young tracking)
  L    Int   @default(0) // losses
  GS   Int   @default(0) // games started
  QS   Int   @default(0) // quality starts (not in MLB API — computed)
  K9   Float @default(0) // strikeouts per 9 innings
  BB9  Float @default(0) // walks per 9 innings
  HR_A Int   @default(0) // home runs allowed
  BF   Int   @default(0) // batters faced
  SHO  Int   @default(0) // shutouts

  // General
  G Int @default(0) // games played/pitched

  player Player @relation(fields: [playerId], references: [id])
  period Period @relation(fields: [periodId], references: [id])

  @@unique([playerId, periodId])
  @@index([periodId])
}

model PlayerStatsDaily {
  id       Int      @id @default(autoincrement())
  playerId Int
  gameDate DateTime @db.Date

  // Batting
  AB  Int @default(0)
  H   Int @default(0)
  R   Int @default(0)
  HR  Int @default(0)
  RBI Int @default(0)
  SB  Int @default(0)

  // Batting — extended
  BB    Int   @default(0)
  HBP   Int   @default(0)
  SF    Int   @default(0)
  TB    Int   @default(0)
  DBL   Int   @default(0)
  TPL   Int   @default(0)
  SO    Int   @default(0)
  OBP   Float @default(0)
  SLG   Float @default(0)
  OPS   Float @default(0)
  GS_HR Int   @default(0) // grand slams

  // Pitching
  W    Int   @default(0)
  SV   Int   @default(0)
  K    Int   @default(0)
  IP   Float @default(0)
  ER   Int   @default(0)
  BB_H Int   @default(0) // walks + hits allowed (for WHIP)

  // Pitching — extended
  L    Int   @default(0)
  GS   Int   @default(0)
  K9   Float @default(0)
  BB9  Float @default(0)
  HR_A Int   @default(0)
  BF   Int   @default(0)
  SHO  Int   @default(0) // shutouts

  // General
  G Int @default(0) // games played/pitched

  player Player @relation(fields: [playerId], references: [id])

  @@unique([playerId, gameDate])
  @@index([gameDate])
  @@index([playerId, gameDate])
}

model Roster {
  id               Int       @id @default(autoincrement())
  teamId           Int
  playerId         Int
  sport            Sport     @default(MLB)
  acquiredAt       DateTime  @default(now())
  releasedAt       DateTime?
  source           String
  price            Int       @default(1)
  assignedPosition String?
  isKeeper         Boolean   @default(false)

  team   Team   @relation(fields: [teamId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@index([teamId])
  @@index([playerId])
  @@index([teamId, sport])
  @@index([teamId, releasedAt, sport])
  @@index([releasedAt, playerId])
}

model Schedule {
  id                Int       @id @default(autoincrement())
  sport             Sport     @default(MLB)
  season            String
  week              Int?
  gameDate          DateTime
  homeFranchiseId   Int
  awayFranchiseId   Int
  externalId        String?
  createdAt         DateTime  @default(now())

  homeFranchise Franchise @relation("HomeFranchise", fields: [homeFranchiseId], references: [id], onDelete: Cascade)
  awayFranchise Franchise @relation("AwayFranchise", fields: [awayFranchiseId], references: [id], onDelete: Cascade)

  @@unique([sport, season, week, homeFranchiseId, awayFranchiseId])
  @@index([sport, season, gameDate])
  @@index([homeFranchiseId])
  @@index([awayFranchiseId])
}

model AuctionLot {
  id               Int       @id @default(autoincrement())
  playerId         Int
  nominatingTeamId Int
  status           String
  startTs          DateTime  @default(now())
  endTs            DateTime?
  finalPrice       Int?
  winnerTeamId     Int?

  player Player @relation(fields: [playerId], references: [id])

  bids AuctionBid[]

  @@index([playerId])
}

model AuctionBid {
  id     Int      @id @default(autoincrement())
  lotId  Int
  teamId Int
  amount Int
  ts     DateTime @default(now())

  lot  AuctionLot @relation(fields: [lotId], references: [id], onDelete: Cascade)
  team Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([lotId])
  @@index([teamId])
}

model FinanceLedger {
  id     Int      @id @default(autoincrement())
  teamId Int
  type   String // entry_fee, bonus, il_fee, auction_adjust, etc.
  amount Int
  reason String?
  ts     DateTime @default(now())

  // Roster-rules-plan additions (2026-04-21): enable per-period IL fees,
  // append-only void/reversal semantics, and actor tracking.
  // All nullable — existing entry_fee/bonus/auction_adjust rows untouched.
  // Required in application layer when type == "il_fee".
  periodId   Int?
  playerId   Int?
  voidedAt   DateTime?
  reversalOf Int?
  createdBy  Int?

  team       Team            @relation(fields: [teamId], references: [id])
  period     Period?         @relation(fields: [periodId], references: [id])
  player     Player?         @relation(fields: [playerId], references: [id])
  reverses   FinanceLedger?  @relation("FinanceLedgerReversal", fields: [reversalOf], references: [id])
  reversedBy FinanceLedger[] @relation("FinanceLedgerReversal")
  // Note: partial unique index scoped to type='il_fee' AND voidedAt IS NULL
  // is expressed in the migration SQL only (Prisma @@unique can't express
  // WHERE clauses). See migration 20260421000000_roster_rules_foundation.

  @@index([teamId])
  @@index([periodId])
  @@index([playerId])
  @@index([teamId, periodId])
}

// ======================
//  Trade & Waiver System
// ======================

model Trade {
  id          Int         @id @default(autoincrement())
  leagueId    Int
  proposerId  Int
  status      TradeStatus @default(PROPOSED)
  createdAt   DateTime    @default(now())
  expiresAt   DateTime?
  processedAt DateTime?
  aiAnalysis  Json?

  items TradeItem[]

  league   League @relation(fields: [leagueId], references: [id])
  proposer Team   @relation("TradeProposer", fields: [proposerId], references: [id])

  @@index([leagueId])
  @@index([proposerId])
  @@index([status])
  @@index([leagueId, status])
  // Backs the AI history merge query (server/src/features/ai/services/
  // aiInsightService.ts) which orders trades by createdAt DESC scoped to a
  // single league. Filtered to rows with non-null aiAnalysis at runtime;
  // Prisma does not support partial-index syntax so we index the full
  // (leagueId, createdAt) range and rely on the WHERE clause to prune.
  @@index([leagueId, createdAt(sort: Desc)])
}

model TradeItem {
  id          Int       @id @default(autoincrement())
  tradeId     Int
  senderId    Int
  recipientId Int
  assetType   AssetType @default(PLAYER)

  // Asset References
  playerId  Int? // If PLAYER
  amount    Int? // If BUDGET, PICK (round), or FUTURE_BUDGET ($)
  pickRound Int? // If PICK
  season    Int? // If PICK or FUTURE_BUDGET: which season it applies to

  trade     Trade   @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  sender    Team    @relation("TradeSender", fields: [senderId], references: [id])
  recipient Team    @relation("TradeRecipient", fields: [recipientId], references: [id])
  player    Player? @relation(fields: [playerId], references: [id])

  @@index([tradeId])
  @@index([senderId])
  @@index([recipientId])
}

model WaiverClaim {
  id           Int         @id @default(autoincrement())
  teamId       Int
  playerId     Int // Player to ADD
  dropPlayerId Int? // Player to DROP (optional)
  bidAmount    Int // FAAB $
  priority     Int // User-defined order
  status       ClaimStatus @default(PENDING)
  processedAt  DateTime?
  createdAt    DateTime    @default(now())
  aiAnalysis   Json?

  // Conditional claim fields
  conditionType     String? // "ONLY_IF_UNAVAILABLE", "ONLY_IF_AVAILABLE", "PAIR_WITH"
  conditionPlayerId Int? // the player the condition references
  conditionNote     String? // human-readable condition description

  team            Team    @relation(fields: [teamId], references: [id])
  player          Player  @relation("ClaimAdd", fields: [playerId], references: [id])
  dropPlayer      Player? @relation("ClaimDrop", fields: [dropPlayerId], references: [id])
  conditionPlayer Player? @relation("ClaimCondition", fields: [conditionPlayerId], references: [id])

  @@index([teamId])
  @@index([status])
}

// ──────────────────────────────────────────────────────────────────
// Waiver Wire List — two-list model (PR #256, supersedes the
// paired-row WaiverClaim approach for the new feature). The legacy
// WaiverClaim model above stays untouched; it backs the existing
// /api/waivers/process auto-engine.
// ──────────────────────────────────────────────────────────────────

model WaiverPeriod {
  id          Int                @id @default(autoincrement())
  leagueId    Int
  deadlineAt  DateTime
  lockedAt    DateTime?
  processedAt DateTime?
  status      WaiverPeriodStatus @default(PENDING)
  createdAt   DateTime           @default(now())

  league      League            @relation(fields: [leagueId], references: [id], onDelete: Restrict)
  addEntries  WaiverAddEntry[]
  dropEntries WaiverDropEntry[]

  @@index([leagueId])
  @@index([status])
  @@index([leagueId, deadlineAt])
}

model WaiverAddEntry {
  id                  Int              @id @default(autoincrement())
  periodId            Int
  teamId              Int
  playerId            Int
  priority            Int
  outcome             WaiverAddOutcome @default(PENDING)
  consumedDropEntryId Int?             @unique // 1:1 — each drop is consumed by at most one add
  reason              String? // free-text failure reason recorded by commissioner
  slotChanges         Json? // owner-directed slot reassignments applied at finalize time
  processedAt         DateTime?
  createdAt           DateTime         @default(now())

  period       WaiverPeriod     @relation(fields: [periodId], references: [id], onDelete: Cascade)
  team         Team             @relation(fields: [teamId], references: [id], onDelete: Restrict)
  player       Player           @relation("WaiverAddPlayer", fields: [playerId], references: [id], onDelete: Restrict)
  consumedDrop WaiverDropEntry? @relation("ConsumedDrop", fields: [consumedDropEntryId], references: [id], onDelete: SetNull)

  @@unique([periodId, teamId, priority]) // one entry per priority slot per (period, team)
  @@unique([periodId, teamId, playerId]) // can't queue same player twice in one period
  @@index([teamId])
  @@index([outcome])
}

model WaiverDropEntry {
  id          Int              @id @default(autoincrement())
  periodId    Int
  teamId      Int
  playerId    Int
  priority    Int
  dropMode    WaiverDropMode   @default(RELEASE)
  status      WaiverDropStatus @default(PENDING)
  slotChanges Json? // owner-directed slot reassignments applied alongside this drop at finalize time
  processedAt DateTime?
  createdAt   DateTime         @default(now())

  period     WaiverPeriod    @relation(fields: [periodId], references: [id], onDelete: Cascade)
  team       Team            @relation(fields: [teamId], references: [id], onDelete: Restrict)
  player     Player          @relation("WaiverDropPlayer", fields: [playerId], references: [id], onDelete: Restrict)
  consumedBy WaiverAddEntry? @relation("ConsumedDrop")

  @@unique([periodId, teamId, priority])
  @@unique([periodId, teamId, playerId])
  @@index([teamId])
  @@index([status])
}

