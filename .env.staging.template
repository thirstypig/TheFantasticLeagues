# .env.staging.template
#
# Copy this file to .env.staging (gitignored) and fill in the placeholders.
# .env.staging is used ONLY by scripts/seed-staging.ts and manual staging
# commands — it is never loaded automatically by the app.
#
# To apply: cp .env.staging.template .env.staging
# Then edit .env.staging with your staging Supabase project values.

# ─── Staging Supabase (separate project from prod) ───────────────────────────
# Both URLs must use the Transaction pooler (port 6543) with ?connection_limit=1
# Free-tier direct connection (port 5432) is IPv6-only and will timeout.
# Get these from: Supabase dashboard → Settings → Database → Transaction pooler

DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-us-west-1.pooler.supabase.com:6543/postgres?connection_limit=1"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-us-west-1.pooler.supabase.com:6543/postgres?connection_limit=1"

# ─── Supabase project credentials ────────────────────────────────────────────
# From: Supabase dashboard → Settings → API

SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY="<staging-anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<staging-service-role-key>"

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=staging
APP_ENV=staging

PORT=3001
CLIENT_URL=http://localhost:5174

# Generate with: openssl rand -hex 32
SESSION_SECRET=<staging-session-secret-change-me>
IP_HASH_SECRET=<staging-ip-hash-secret-change-me>

ADMIN_EMAILS=jimmyc316@gmail.com

# ─── Push notifications (VAPID) — optional for staging ───────────────────────
# Generate with: npx web-push generate-vapid-keys
# Leave blank to disable push notifications in staging
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── AI (optional for staging) ───────────────────────────────────────────────
# Leave blank to disable AI insights in staging
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ─── Stats APIs ──────────────────────────────────────────────────────────────
# MLB Stats API is public — no key needed
# NFL (Phase 2): ESPN_S2 cookie value from browser dev tools while logged into ESPN
# ESPN_S2=
